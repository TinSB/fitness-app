# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Xcode / SwiftPM generated state
**/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcworkspace/xcuserdata/
**/DerivedData/
**/.swiftpm/xcode/
**/.build/
.build/

# local data / backups
*.local
*.bak
*.backup
*.sqlite
*.sqlite-wal
*.sqlite-shm
.ironpath/

# environment and logs
.env
.env.*
*.log

# Local Codex task prompts/logs
.codex-tasks/
.codex-tools/
.codegraph/
.ai-tmp/

# Local doc scratch / throwaway artifacts
_slices/
_scratch/

# Local clay render workspace artifacts only — canonical icons ARE tracked
# (assets/clay/<kind>.<name>.png landed in #508; do NOT blanket-ignore assets/)
assets/clay.zip
assets/clay/_*
assets/clay/__pycache__/
assets/clay/.~lock*
# Render-workspace scratch (build scripts, masters, blueprint, handoff brief) —
# local-only Larder/Blender pipeline, must never be committed into the repo tree.
assets/clay/*.py
assets/clay/*.xlsx
assets/clay/CLAY_*.md
assets/clay/masters/

# Local tool launchers
.claude/launch.json

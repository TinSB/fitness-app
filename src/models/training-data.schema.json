{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironpath.local/schemas/training-data.schema.json",
  "title": "IronPath AppData",
  "type": "object",
  "required": [
    "schemaVersion",
    "templates",
    "history",
    "activeSession",
    "todayStatus",
    "bodyWeights",
    "userProfile",
    "screeningProfile",
    "programTemplate",
    "mesocyclePlan",
    "settings"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "templates": { "type": "array", "items": { "$ref": "#/$defs/trainingTemplate" } },
    "history": { "type": "array", "items": { "$ref": "#/$defs/trainingSession" } },
    "activeSession": {
      "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/trainingSession" }]
    },
    "selectedTemplateId": { "type": "string" },
    "trainingMode": { "type": "string", "enum": ["hybrid", "strength", "hypertrophy"] },
    "todayStatus": { "$ref": "#/$defs/todayStatus" },
    "bodyWeights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "value"],
        "properties": {
          "date": { "type": "string" },
          "value": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "healthMetricSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/healthMetricSample" }
    },
    "importedWorkoutSamples": {
      "type": "array",
      "items": { "$ref": "#/$defs/importedWorkoutSample" }
    },
    "healthImportBatches": {
      "type": "array",
      "items": { "$ref": "#/$defs/healthImportBatch" }
    },
    "dismissedCoachActions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dismissedCoachAction" }
    },
    "userProfile": { "$ref": "#/$defs/userProfile" },
    "screeningProfile": { "$ref": "#/$defs/screeningProfile" },
    "programTemplate": { "$ref": "training-program.schema.json" },
    "mesocyclePlan": { "$ref": "#/$defs/mesocyclePlan" },
    "programAdjustmentDrafts": {
      "type": "array",
      "items": { "$ref": "#/$defs/programAdjustmentDraft" }
    },
    "programAdjustmentHistory": {
      "type": "array",
      "items": { "$ref": "#/$defs/programAdjustmentHistoryItem" }
    },
    "activeProgramTemplateId": { "type": "string" },
    "settings": {
      "type": "object",
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "selectedTemplateId": { "type": "string" },
        "trainingMode": { "type": "string", "enum": ["hybrid", "strength", "hypertrophy"] },
        "activeProgramTemplateId": { "type": "string" },
        "programAdjustmentDrafts": {
          "type": "array",
          "items": { "$ref": "#/$defs/programAdjustmentDraft" }
        },
        "programAdjustmentHistory": {
          "type": "array",
          "items": { "$ref": "#/$defs/programAdjustmentHistoryItem" }
        },
        "dismissedCoachActions": {
          "type": "array",
          "items": { "$ref": "#/$defs/dismissedCoachAction" }
        },
        "healthIntegrationSettings": {
          "type": "object",
          "properties": {
            "useHealthDataForReadiness": { "type": "boolean" },
            "showExternalWorkoutsInCalendar": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "dismissedCoachAction": {
      "type": "object",
      "required": ["actionId", "dismissedAt", "scope"],
      "properties": {
        "actionId": { "type": "string" },
        "dismissedAt": { "type": "string" },
        "scope": { "type": "string", "enum": ["today"] }
      },
      "additionalProperties": true
    },
    "dataFlag": { "type": "string", "enum": ["normal", "test", "excluded"] },
    "healthDataSource": {
      "type": "string",
      "enum": ["apple_health_export", "apple_watch_workout", "third_party_csv", "manual_import", "unknown"]
    },
    "healthMetricType": {
      "type": "string",
      "enum": [
        "sleep_duration",
        "resting_heart_rate",
        "hrv",
        "heart_rate",
        "steps",
        "active_energy",
        "exercise_minutes",
        "body_weight",
        "body_fat",
        "vo2max",
        "workout"
      ]
    },
    "healthMetricSample": {
      "type": "object",
      "required": ["id", "source", "metricType", "startDate", "value", "unit", "importedAt"],
      "properties": {
        "id": { "type": "string" },
        "source": { "$ref": "#/$defs/healthDataSource" },
        "sourceName": { "type": "string" },
        "deviceSourceName": { "type": "string" },
        "metricType": { "$ref": "#/$defs/healthMetricType" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "value": { "type": "number", "minimum": 0 },
        "unit": { "type": "string" },
        "importedAt": { "type": "string" },
        "batchId": { "type": "string" },
        "dataFlag": { "$ref": "#/$defs/dataFlag" }
      },
      "additionalProperties": true
    },
    "importedWorkoutSample": {
      "type": "object",
      "required": ["id", "source", "workoutType", "startDate", "endDate", "durationMin", "importedAt"],
      "properties": {
        "id": { "type": "string" },
        "source": { "$ref": "#/$defs/healthDataSource" },
        "sourceName": { "type": "string" },
        "deviceSourceName": { "type": "string" },
        "workoutType": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "durationMin": { "type": "number", "minimum": 0 },
        "activeEnergyKcal": { "type": "number", "minimum": 0 },
        "avgHeartRate": { "type": "number", "minimum": 0 },
        "maxHeartRate": { "type": "number", "minimum": 0 },
        "distanceMeters": { "type": "number", "minimum": 0 },
        "importedAt": { "type": "string" },
        "batchId": { "type": "string" },
        "dataFlag": { "$ref": "#/$defs/dataFlag" }
      },
      "additionalProperties": true
    },
    "healthImportBatch": {
      "type": "object",
      "required": ["id", "importedAt", "source", "sampleCount", "workoutCount", "notes"],
      "properties": {
        "id": { "type": "string" },
        "importedAt": { "type": "string" },
        "source": { "$ref": "#/$defs/healthDataSource" },
        "fileName": { "type": "string" },
        "sampleCount": { "type": "number", "minimum": 0 },
        "workoutCount": { "type": "number", "minimum": 0 },
        "newSampleCount": { "type": "number", "minimum": 0 },
        "duplicateSampleCount": { "type": "number", "minimum": 0 },
        "skippedSampleCount": { "type": "number", "minimum": 0 },
        "newWorkoutCount": { "type": "number", "minimum": 0 },
        "duplicateWorkoutCount": { "type": "number", "minimum": 0 },
        "skippedWorkoutCount": { "type": "number", "minimum": 0 },
        "notes": { "type": "array", "items": { "type": "string" } },
        "dataFlag": { "$ref": "#/$defs/dataFlag" }
      },
      "additionalProperties": true
    },
    "todayStatus": {
      "type": "object",
      "required": ["sleep", "energy", "soreness", "time"],
      "properties": {
        "sleep": { "type": "string", "enum": ["差", "一般", "好"] },
        "energy": { "type": "string", "enum": ["低", "中", "高"] },
        "soreness": { "type": "array", "items": { "type": "string" } },
        "time": { "type": "string", "enum": ["30", "60", "90"] },
        "date": { "type": "string" }
      },
      "additionalProperties": true
    },
    "userProfile": {
      "type": "object",
      "required": [
        "id",
        "name",
        "sex",
        "age",
        "heightCm",
        "weightKg",
        "trainingLevel",
        "primaryGoal",
        "secondaryPreferences",
        "weeklyTrainingDays",
        "sessionDurationMin",
        "equipmentAccess",
        "injuryFlags",
        "painNotes"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sex": { "type": "string", "enum": ["male", "female", "other"] },
        "age": { "type": "number", "minimum": 0 },
        "heightCm": { "type": "number", "minimum": 0 },
        "weightKg": { "type": "number", "minimum": 0 },
        "trainingLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "primaryGoal": { "type": "string", "enum": ["hypertrophy", "strength", "fat_loss"] },
        "secondaryPreferences": { "type": "array", "items": { "type": "string" } },
        "weeklyTrainingDays": { "type": "number", "minimum": 1 },
        "sessionDurationMin": { "type": "number", "minimum": 1 },
        "equipmentAccess": { "type": "array", "items": { "type": "string" } },
        "injuryFlags": { "type": "array", "items": { "type": "string" } },
        "painNotes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "screeningProfile": {
      "type": "object",
      "required": ["userId", "postureFlags", "movementFlags", "painTriggers", "restrictedExercises", "correctionPriority"],
      "properties": {
        "userId": { "type": "string" },
        "postureFlags": { "type": "object", "additionalProperties": { "type": "string" } },
        "movementFlags": { "type": "object", "additionalProperties": { "type": "string" } },
        "painTriggers": { "type": "array", "items": { "type": "string" } },
        "restrictedExercises": { "type": "array", "items": { "type": "string" } },
        "correctionPriority": { "type": "array", "items": { "type": "string" } },
        "adaptiveState": {
          "type": "object",
          "properties": {
            "issueScores": { "type": "object", "additionalProperties": { "type": "number" } },
            "painByExercise": { "type": "object", "additionalProperties": { "type": "number" } },
            "performanceDrops": { "type": "array", "items": { "type": "string" } },
            "improvingIssues": { "type": "array", "items": { "type": "string" } },
            "moduleDose": { "type": "object", "additionalProperties": { "type": "string" } },
            "lastUpdated": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "trainingSet": {
      "type": "object",
      "required": ["id", "weight", "reps"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "weight": { "type": "number", "minimum": 0 },
        "reps": { "type": "number", "minimum": 0 },
        "rpe": {},
        "rir": {},
        "note": { "type": "string" },
        "painFlag": { "type": "boolean" },
        "painArea": { "type": "string" },
        "painSeverity": { "type": "number", "minimum": 0, "maximum": 5 },
        "techniqueQuality": { "type": "string", "enum": ["good", "acceptable", "poor"] },
        "done": { "type": "boolean" },
        "completedAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "exerciseTemplate": {
      "type": "object",
      "required": ["id", "name", "muscle", "kind", "sets", "repMin", "repMax", "rest", "startWeight"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "alias": { "type": "string" },
        "muscle": { "type": "string" },
        "kind": { "type": "string" },
        "sets": {
          "anyOf": [
            { "type": "number", "minimum": 0 },
            { "type": "array", "items": { "$ref": "#/$defs/trainingSet" } }
          ]
        },
        "repMin": { "type": "number", "minimum": 0 },
        "repMax": { "type": "number", "minimum": 0 },
        "rest": { "type": "number", "minimum": 0 },
        "startWeight": { "type": "number", "minimum": 0 },
        "alternatives": { "type": "array", "items": { "type": "string" } },
        "primaryMuscles": { "type": "array", "items": { "type": "string" } },
        "secondaryMuscles": { "type": "array", "items": { "type": "string" } },
        "targetRir": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
      },
      "additionalProperties": true
    },
    "trainingTemplate": {
      "type": "object",
      "required": ["id", "name", "focus", "duration", "note", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "focus": { "type": "string" },
        "duration": { "type": "number", "minimum": 0 },
        "note": { "type": "string" },
        "updatedAt": { "type": "string" },
        "sourceTemplateId": { "type": "string" },
        "sourceTemplateName": { "type": "string" },
        "isExperimentalTemplate": { "type": "boolean" },
        "appliedAt": { "type": "string" },
        "adjustmentSummary": { "type": "string" },
        "exercises": { "type": "array", "items": { "$ref": "#/$defs/exerciseTemplate" } }
      },
      "additionalProperties": true
    },
    "supportExercise": {
      "type": "object",
      "required": ["exerciseId", "sets"],
      "properties": {
        "exerciseId": { "type": "string" },
        "name": { "type": "string" },
        "sets": { "type": "number", "minimum": 0 },
        "repMin": { "type": "number", "minimum": 0 },
        "repMax": { "type": "number", "minimum": 0 },
        "holdSec": { "type": "number", "minimum": 0 },
        "distanceM": { "type": "number", "minimum": 0 },
        "timeSec": { "type": "number", "minimum": 0 },
        "restSec": { "type": "number", "minimum": 0 },
        "cue": { "type": "string" }
      },
      "additionalProperties": true
    },
    "supportExerciseLog": {
      "type": "object",
      "required": ["moduleId", "exerciseId", "blockType", "plannedSets", "completedSets"],
      "properties": {
        "moduleId": { "type": "string" },
        "exerciseId": { "type": "string" },
        "exerciseName": { "type": "string" },
        "blockType": { "type": "string", "enum": ["correction", "functional"] },
        "plannedSets": { "type": "number", "minimum": 0 },
        "completedSets": { "type": "number", "minimum": 0 },
        "skippedReason": { "type": "string", "enum": ["time", "pain", "equipment", "forgot", "too_tired", "not_needed", "other"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "loadFeedback": {
      "type": "object",
      "required": ["exerciseId", "sessionId", "date", "feedback"],
      "properties": {
        "exerciseId": { "type": "string" },
        "sessionId": { "type": "string" },
        "date": { "type": "string" },
        "feedback": { "type": "string", "enum": ["too_light", "good", "too_heavy"] },
        "note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "restTimerState": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["exerciseId", "setIndex", "startedAt", "durationSec", "isRunning"],
          "properties": {
            "exerciseId": { "type": "string" },
            "setIndex": { "type": "number", "minimum": 0 },
            "startedAt": { "type": "string" },
            "durationSec": { "type": "number", "minimum": 0 },
            "isRunning": { "type": "boolean" },
            "pausedRemainingSec": { "type": "number", "minimum": 0 },
            "label": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "adjustmentChange": {
      "type": "object",
      "required": ["id", "type", "reason"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["add_sets", "remove_sets", "add_new_exercise", "swap_exercise", "reduce_support", "increase_support", "keep"] },
        "dayTemplateId": { "type": "string" },
        "dayTemplateName": { "type": "string" },
        "exerciseId": { "type": "string" },
        "exerciseName": { "type": "string" },
        "replacementExerciseId": { "type": "string" },
        "replacementExerciseName": { "type": "string" },
        "muscleId": { "type": "string" },
        "setsDelta": { "type": "number" },
        "sets": { "type": "number" },
        "repMin": { "type": "number" },
        "repMax": { "type": "number" },
        "restSec": { "type": "number" },
        "insertAfterExerciseId": { "type": "string" },
        "insertPositionLabel": { "type": "string" },
        "previewNote": { "type": "string" },
        "skipped": { "type": "boolean" },
        "skipReason": { "type": "string" },
        "reason": { "type": "string" },
        "sourceRecommendationId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "programAdjustmentDraft": {
      "type": "object",
      "required": ["id", "createdAt", "status", "sourceProgramTemplateId", "title", "summary", "selectedRecommendationIds", "changes", "confidence", "notes"],
      "properties": {
        "id": { "type": "string" },
        "parentDraftId": { "type": "string" },
        "draftRevision": { "type": "integer", "minimum": 1 },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["recommendation", "draft_created", "ready_to_apply", "draft", "previewed", "applied", "rolled_back", "dismissed", "expired", "stale"] },
        "sourceProgramTemplateId": { "type": "string" },
        "sourceTemplateId": { "type": "string" },
        "sourceCoachActionId": { "type": "string" },
        "sourceRecommendationId": { "type": "string" },
        "sourceFingerprint": { "type": "string" },
        "experimentalProgramTemplateId": { "type": "string" },
        "sourceTemplateSnapshotHash": { "type": "string" },
        "sourceTemplateUpdatedAt": { "type": "string" },
        "appliedAt": { "type": "string" },
        "rolledBackAt": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "selectedRecommendationIds": { "type": "array", "items": { "type": "string" } },
        "changes": { "type": "array", "items": { "$ref": "#/$defs/adjustmentChange" } },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "programAdjustmentHistoryItem": {
      "type": "object",
      "required": ["id", "appliedAt", "sourceProgramTemplateId", "experimentalProgramTemplateId", "selectedRecommendationIds", "changes", "rollbackAvailable"],
      "properties": {
        "id": { "type": "string" },
        "appliedAt": { "type": "string" },
        "sourceProgramTemplateId": { "type": "string" },
        "experimentalProgramTemplateId": { "type": "string" },
        "sourceCoachActionId": { "type": "string" },
        "sourceFingerprint": { "type": "string" },
        "sourceProgramTemplateName": { "type": "string" },
        "experimentalProgramTemplateName": { "type": "string" },
        "mainChangeSummary": { "type": "string" },
        "selectedRecommendationIds": { "type": "array", "items": { "type": "string" } },
        "changes": { "type": "array", "items": { "$ref": "#/$defs/adjustmentChange" } },
        "rollbackAvailable": { "type": "boolean" },
        "rolledBackAt": { "type": "string" },
        "sourceProgramSnapshot": { "$ref": "training-program.schema.json" },
        "effectReview": {
          "type": "object",
          "required": ["historyItemId", "status", "confidence", "summary", "metrics", "recommendation"],
          "properties": {
            "historyItemId": { "type": "string" },
            "status": { "type": "string", "enum": ["too_early", "improved", "neutral", "worse", "insufficient_data"] },
            "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
            "summary": { "type": "string" },
            "metrics": {
              "type": "object",
              "properties": {
                "targetMuscleChange": { "type": "number" },
                "adherenceChange": { "type": "number" },
                "painSignalChange": { "type": "number" },
                "effectiveVolumeChange": { "type": "number" },
                "beforeSessionCount": { "type": "number" },
                "afterSessionCount": { "type": "number" }
              },
              "additionalProperties": true
            },
            "recommendation": { "type": "string", "enum": ["keep", "rollback", "review_manually", "collect_more_data"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "supportModule": {
      "type": "object",
      "required": ["id", "name", "durationMin", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "durationMin": { "type": "number", "minimum": 0 },
        "exercises": { "type": "array", "items": { "$ref": "#/$defs/supportExercise" } }
      },
      "additionalProperties": true
    },
    "mesocycleWeek": {
      "type": "object",
      "required": ["weekIndex", "phase", "volumeMultiplier", "intensityBias"],
      "properties": {
        "weekIndex": { "type": "integer", "minimum": 0 },
        "phase": { "type": "string", "enum": ["base", "build", "overload", "deload"] },
        "volumeMultiplier": { "type": "number", "minimum": 0.4, "maximum": 1.3 },
        "intensityBias": { "type": "string", "enum": ["conservative", "normal", "aggressive"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "mesocyclePlan": {
      "type": "object",
      "required": ["id", "startDate", "lengthWeeks", "currentWeekIndex", "primaryGoal", "weeks"],
      "properties": {
        "id": { "type": "string" },
        "startDate": { "type": "string" },
        "lengthWeeks": { "type": "integer", "enum": [4, 5, 6] },
        "currentWeekIndex": { "type": "integer", "minimum": 0 },
        "primaryGoal": { "type": "string", "enum": ["hypertrophy", "strength", "fat_loss"] },
        "weeks": { "type": "array", "items": { "$ref": "#/$defs/mesocycleWeek" } }
      },
      "additionalProperties": true
    },
    "trainingSession": {
      "type": "object",
      "required": ["id", "date", "templateId", "templateName", "trainingMode", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "templateId": { "type": "string" },
        "templateName": { "type": "string" },
        "programTemplateId": { "type": "string" },
        "programTemplateName": { "type": "string" },
        "isExperimentalTemplate": { "type": "boolean" },
        "sourceProgramTemplateId": { "type": "string" },
        "sourceProgramTemplateName": { "type": "string" },
        "trainingMode": { "type": "string", "enum": ["hybrid", "strength", "hypertrophy"] },
        "focus": { "type": "string" },
        "exercises": { "type": "array", "items": { "$ref": "#/$defs/exerciseTemplate" } },
        "correctionBlock": { "type": "array", "items": { "$ref": "#/$defs/supportModule" } },
        "functionalBlock": { "type": "array", "items": { "$ref": "#/$defs/supportModule" } },
        "supportExerciseLogs": { "type": "array", "items": { "$ref": "#/$defs/supportExerciseLog" } },
        "loadFeedback": { "type": "array", "items": { "$ref": "#/$defs/loadFeedback" } },
        "restTimerState": { "$ref": "#/$defs/restTimerState" },
        "status": { "$ref": "#/$defs/todayStatus" },
        "durationMin": { "type": "number", "minimum": 0 },
        "completed": { "type": "boolean" },
        "startedAt": { "type": "string" },
        "finishedAt": { "type": "string" },
        "explanations": { "type": "array", "items": { "type": "string" } },
        "editedAt": { "type": "string" },
        "editHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["editedAt", "fields"],
            "properties": {
              "editedAt": { "type": "string" },
              "fields": { "type": "array", "items": { "type": "string" } },
              "note": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  }
}
